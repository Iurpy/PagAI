<UserControl x:Class="PagAI.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!-- SAUDAÇÃO -->
            <StackPanel Margin="0,0,0,26">
                <TextBlock Text="Bem-vindo de volta"
                           FontSize="15"
                           Foreground="{StaticResource MutedBrush}"/>

                <TextBlock x:Name="TxtNomeUsuario"
                           Text="Usuário"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- CARDS PRINCIPAIS -->
            <UniformGrid Columns="3"
                         Margin="0,0,0,26">

                <Border Style="{StaticResource DashboardCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Capital exposto"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"/>

                        <TextBlock x:Name="TxtCapitalEmprestado"
                                   Text="R$ 0,00"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,12,0,4"/>

                        <TextBlock Text="Dinheiro ainda emprestado aos clientes"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashboardCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Total recebido"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"/>

                        <TextBlock x:Name="TxtTotalRecebido"
                                   Text="R$ 0,00"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#22C55E"
                                   Margin="0,12,0,4"/>

                        <TextBlock Text="Pagamentos registrados"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashboardCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Em aberto"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"/>

                        <TextBlock x:Name="TxtTotalEmAberto"
                                   Text="R$ 0,00"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#FACC15"
                                   Margin="0,12,0,4"/>

                        <TextBlock Text="Valor restante das parcelas"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- CARDS SECUNDÁRIOS -->
            <UniformGrid Columns="4"
                         Margin="0,0,0,26">

                <Border Style="{StaticResource DashboardCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Clientes com contrato"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"/>

                        <TextBlock x:Name="TxtClientesComContrato"
                                   Text="0"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,12,0,4"/>

                        <TextBlock Text="Clientes movimentados"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashboardCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Contratos ativos"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"/>

                        <TextBlock x:Name="TxtContratosAtivos"
                                   Text="0"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#38BDF8"
                                   Margin="0,12,0,4"/>

                        <TextBlock Text="Em andamento"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashboardCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Contratos quitados"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"/>

                        <TextBlock x:Name="TxtContratosFinalizados"
                                   Text="0"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#22C55E"
                                   Margin="0,12,0,4"/>

                        <TextBlock Text="Finalizados"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashboardCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Parcelas atrasadas"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"/>

                        <TextBlock x:Name="TxtParcelasAtrasadas"
                                   Text="0"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#EF4444"
                                   Margin="0,12,0,4"/>

                        <TextBlock Text="Precisam de atenção"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- ÁREA INFERIOR -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- PRÓXIMOS VENCIMENTOS -->
                <Border Grid.Column="0"
                        Style="{StaticResource CardStyle}"
                        Margin="0,0,16,0">

                    <StackPanel>
                        <TextBlock Text="Próximos vencimentos"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Parcelas pendentes ou atrasadas mais próximas"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="0,8,0,18"/>

                        <ItemsControl x:Name="ListaVencimentos">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0B1220"
                                            BorderBrush="#1E293B"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="14"
                                            Margin="0,0,0,10"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="AbrirContrato_Click">

                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Left">
                                                <TextBlock Text="{Binding Cliente}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           Foreground="White"/>

                                                <TextBlock Text="{Binding Descricao}"
                                                           FontSize="13"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           Margin="0,4,0,0"/>

                                                <TextBlock Text="{Binding Vencimento}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding CorVencimento}"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>

                                            <TextBlock Text="{Binding Valor}"
                                                       DockPanel.Dock="Right"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       Foreground="#FACC15"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="TxtSemVencimentos"
                                   Text="Nenhum vencimento encontrado."
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- ÚLTIMOS RECEBIMENTOS -->
                <Border Grid.Column="1"
                        Style="{StaticResource CardStyle}">

                    <StackPanel>
                        <TextBlock Text="Últimos recebimentos"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Pagamentos registrados recentemente"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="0,8,0,18"/>

                        <ItemsControl x:Name="ListaRecebimentos">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0B1220"
                                            BorderBrush="#1E293B"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="14"
                                            Margin="0,0,0,10"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="AbrirContrato_Click">

                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Left">
                                                <TextBlock Text="{Binding Cliente}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           Foreground="White"/>

                                                <TextBlock Text="{Binding Contrato}"
                                                           FontSize="13"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           Margin="0,4,0,0"/>

                                                <TextBlock Text="{Binding DataPagamento}"
                                                           FontSize="13"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>

                                            <TextBlock Text="{Binding Valor}"
                                                       DockPanel.Dock="Right"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       Foreground="#22C55E"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="TxtSemRecebimentos"
                                   Text="Nenhum pagamento registrado."
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- CONTRATOS RECENTES -->
            <Border Style="{StaticResource CardStyle}"
                    Margin="0,26,0,0">

                <StackPanel>
                    <TextBlock Text="Contratos recentes"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock Text="Últimos contratos cadastrados no sistema"
                               FontSize="14"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,8,0,18"/>

                    <ItemsControl x:Name="ListaContratosRecentes">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0B1220"
                                        BorderBrush="#1E293B"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="14"
                                        Margin="0,0,0,10"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="AbrirContrato_Click">

                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Left">
                                            <TextBlock Text="{Binding Titulo}"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       Foreground="White"/>

                                            <TextBlock Text="{Binding Cliente}"
                                                       FontSize="13"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       Margin="0,4,0,0"/>

                                            <TextBlock Text="{Binding DataCadastro}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <StackPanel DockPanel.Dock="Right"
                                                    VerticalAlignment="Center">

                                            <TextBlock Text="{Binding ValorTotal}"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Right"/>

                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding CorStatus}"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="TxtSemContratos"
                               Text="Nenhum contrato cadastrado."
                               FontSize="14"
                               Foreground="{StaticResource MutedBrush}"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>