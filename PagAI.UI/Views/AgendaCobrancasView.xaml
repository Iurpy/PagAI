<UserControl x:Class="PagAI.UI.Views.AgendaCobrancasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <TextBlock Text="Agenda de cobranças"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="White"/>

            <TextBlock Text="Parcelas atrasadas, vencendo hoje e próximas cobranças"
                       FontSize="15"
                       Foreground="{StaticResource MutedBrush}"
                       Margin="0,6,0,26"/>

            <Grid Margin="0,0,0,26">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource DashboardCardStyle}"
                        Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Atrasadas"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"/>

                        <TextBlock x:Name="TxtTotalAtrasadas"
                                   Text="0"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#EF4444"
                                   Margin="0,12,0,4"/>

                        <TextBlock x:Name="TxtValorAtrasado"
                                   Text="R$ 0,00"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource DashboardCardStyle}"
                        Margin="12,0">
                    <StackPanel>
                        <TextBlock Text="Vencendo hoje"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"/>

                        <TextBlock x:Name="TxtTotalHoje"
                                   Text="0"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#FACC15"
                                   Margin="0,12,0,4"/>

                        <TextBlock x:Name="TxtValorHoje"
                                   Text="R$ 0,00"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource DashboardCardStyle}"
                        Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Próximos 7 dias"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"/>

                        <TextBlock x:Name="TxtTotalProximos"
                                   Text="0"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#38BDF8"
                                   Margin="0,12,0,4"/>

                        <TextBlock x:Name="TxtValorProximos"
                                   Text="R$ 0,00"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>

                    <TextBlock Text="Atrasadas"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,16"/>

                    <ItemsControl x:Name="ListaAtrasadas">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0B1220"
                                        BorderBrush="#1E293B"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="14"
                                        Margin="0,0,0,10"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="AbrirContrato_Click">

                                    <StackPanel>
                                        <TextBlock Text="{Binding Cliente}"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="White"/>

                                        <TextBlock Text="{Binding Descricao}"
                                                   FontSize="13"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   Margin="0,4,0,0"/>

                                        <TextBlock Text="{Binding Valor}"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="#EF4444"
                                                   Margin="0,8,0,0"/>

                                        <TextBlock Text="{Binding Situacao}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#EF4444"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="TxtSemAtrasadas"
                               Text="Nenhuma parcela atrasada."
                               FontSize="14"
                               Foreground="{StaticResource MutedBrush}"
                               Visibility="Collapsed"/>

                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}"
                    Margin="0,18,0,0">
                <StackPanel>

                    <TextBlock Text="Vencendo hoje"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,16"/>

                    <ItemsControl x:Name="ListaHoje">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0B1220"
                                        BorderBrush="#1E293B"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="14"
                                        Margin="0,0,0,10"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="AbrirContrato_Click">

                                    <StackPanel>
                                        <TextBlock Text="{Binding Cliente}"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="White"/>

                                        <TextBlock Text="{Binding Descricao}"
                                                   FontSize="13"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   Margin="0,4,0,0"/>

                                        <TextBlock Text="{Binding Valor}"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="#FACC15"
                                                   Margin="0,8,0,0"/>

                                        <TextBlock Text="{Binding Situacao}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FACC15"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="TxtSemHoje"
                               Text="Nenhuma cobrança para hoje."
                               FontSize="14"
                               Foreground="{StaticResource MutedBrush}"
                               Visibility="Collapsed"/>

                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}"
                    Margin="0,18,0,0">
                <StackPanel>

                    <TextBlock Text="Próximos 7 dias"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,16"/>

                    <ItemsControl x:Name="ListaProximos">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0B1220"
                                        BorderBrush="#1E293B"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="14"
                                        Margin="0,0,0,10"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="AbrirContrato_Click">

                                    <StackPanel>
                                        <TextBlock Text="{Binding Cliente}"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="White"/>

                                        <TextBlock Text="{Binding Descricao}"
                                                   FontSize="13"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   Margin="0,4,0,0"/>

                                        <TextBlock Text="{Binding Valor}"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="#38BDF8"
                                                   Margin="0,8,0,0"/>

                                        <TextBlock Text="{Binding Situacao}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#38BDF8"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="TxtSemProximos"
                               Text="Nenhuma cobrança nos próximos 7 dias."
                               FontSize="14"
                               Foreground="{StaticResource MutedBrush}"
                               Visibility="Collapsed"/>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>