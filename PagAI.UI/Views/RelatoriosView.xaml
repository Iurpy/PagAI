<UserControl x:Class="PagAI.UI.Views.RelatoriosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <StackPanel Margin="0,0,0,26">
                <TextBlock Text="Relatórios"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock Text="Resumo financeiro, contratos, recebimentos e inadimplência"
                           FontSize="15"
                           Foreground="{StaticResource MutedBrush}"
                           Margin="0,6,0,0"/>
            </StackPanel>

            <UniformGrid Columns="4"
                         Margin="0,0,0,26">

                <Border Style="{StaticResource DashboardCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Total emprestado"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"/>

                        <TextBlock x:Name="TxtTotalEmprestado"
                                   Text="R$ 0,00"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,12,0,4"/>

                        <TextBlock Text="Histórico geral"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashboardCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Total com juros"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"/>

                        <TextBlock x:Name="TxtTotalComJuros"
                                   Text="R$ 0,00"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#38BDF8"
                                   Margin="0,12,0,4"/>

                        <TextBlock Text="Valor previsto"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashboardCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Total recebido"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"/>

                        <TextBlock x:Name="TxtTotalRecebido"
                                   Text="R$ 0,00"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#22C55E"
                                   Margin="0,12,0,4"/>

                        <TextBlock Text="Pagamentos realizados"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashboardCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Em aberto"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"/>

                        <TextBlock x:Name="TxtTotalEmAberto"
                                   Text="R$ 0,00"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#FACC15"
                                   Margin="0,12,0,4"/>

                        <TextBlock Text="Ainda a receber"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <UniformGrid Columns="4"
                         Margin="0,0,0,26">

                <Border Style="{StaticResource DashboardCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Lucro previsto"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"/>

                        <TextBlock x:Name="TxtLucroPrevisto"
                                   Text="R$ 0,00"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#22C55E"
                                   Margin="0,12,0,4"/>

                        <TextBlock Text="Juros estimados"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashboardCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Contratos"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"/>

                        <TextBlock x:Name="TxtTotalContratos"
                                   Text="0"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,12,0,4"/>

                        <TextBlock Text="Total cadastrados"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashboardCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Contratos ativos"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"/>

                        <TextBlock x:Name="TxtContratosAtivos"
                                   Text="0"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#38BDF8"
                                   Margin="0,12,0,4"/>

                        <TextBlock Text="Em andamento"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashboardCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Parcelas atrasadas"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"/>

                        <TextBlock x:Name="TxtParcelasAtrasadas"
                                   Text="0"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#EF4444"
                                   Margin="0,12,0,4"/>

                        <TextBlock Text="Inadimplência"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <Border Style="{StaticResource CardStyle}"
                    Margin="0,0,0,22">

                <StackPanel>
                    <TextBlock Text="Contratos"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,16"/>

                    <ItemsControl x:Name="ListaContratos">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0B1220"
                                        BorderBrush="#1E293B"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="14"
                                        Margin="0,0,0,10"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="AbrirContrato_Click">

                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Left">
                                            <TextBlock Text="{Binding Titulo}"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       Foreground="White"/>

                                            <TextBlock Text="{Binding Cliente}"
                                                       FontSize="13"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       Margin="0,4,0,0"/>

                                            <TextBlock Text="{Binding DataContrato}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <StackPanel DockPanel.Dock="Right"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ValorTotal}"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Right"/>

                                            <TextBlock Text="{Binding Resumo}"
                                                       FontSize="13"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,4,0,0"/>

                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding CorStatus}"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="TxtSemContratos"
                               Text="Nenhum contrato encontrado."
                               FontSize="14"
                               Foreground="{StaticResource MutedBrush}"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource CardStyle}"
                        Margin="0,0,12,0">

                    <StackPanel>
                        <TextBlock Text="Últimos recebimentos"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,16"/>

                        <ItemsControl x:Name="ListaRecebimentos">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0B1220"
                                            BorderBrush="#1E293B"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="14"
                                            Margin="0,0,0,10"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="AbrirContrato_Click">

                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Left">
                                                <TextBlock Text="{Binding Cliente}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           Foreground="White"/>

                                                <TextBlock Text="{Binding Descricao}"
                                                           FontSize="13"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           Margin="0,4,0,0"/>

                                                <TextBlock Text="{Binding DataPagamento}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>

                                            <TextBlock Text="{Binding Valor}"
                                                       DockPanel.Dock="Right"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       Foreground="#22C55E"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="TxtSemRecebimentos"
                                   Text="Nenhum recebimento registrado."
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource CardStyle}"
                        Margin="12,0,0,0">

                    <StackPanel>
                        <TextBlock Text="Inadimplentes"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,16"/>

                        <ItemsControl x:Name="ListaInadimplentes">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0B1220"
                                            BorderBrush="#1E293B"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="14"
                                            Margin="0,0,0,10"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="AbrirContrato_Click">

                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Left">
                                                <TextBlock Text="{Binding Cliente}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           Foreground="White"/>

                                                <TextBlock Text="{Binding Descricao}"
                                                           FontSize="13"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           Margin="0,4,0,0"/>

                                                <TextBlock Text="{Binding Atraso}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="#EF4444"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>

                                            <TextBlock Text="{Binding Valor}"
                                                       DockPanel.Dock="Right"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       Foreground="#EF4444"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="TxtSemInadimplentes"
                                   Text="Nenhum cliente inadimplente."
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>