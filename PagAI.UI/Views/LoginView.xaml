<UserControl x:Class="PagAI.UI.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="460"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center">

            <TextBlock Text="PagAI"
                       FontSize="42"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Gerencie clientes, contratos e recebimentos"
                       FontSize="16"
                       Foreground="{StaticResource MutedBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,35"/>

            <Border Background="{StaticResource Surface2Brush}"
                    CornerRadius="24"
                    Padding="38"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="1">

                <StackPanel>

                    <TextBlock Text="Bem-vindo de volta"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Entre na sua conta para continuar"
                               FontSize="15"
                               Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,30"/>

                    <Label Content="Login"/>

                    <TextBox x:Name="TxtLogin"
                             Style="{StaticResource InputTextBoxStyle}"
                             Margin="0,6,0,18"/>

                    <Label Content="Senha"/>

                    <PasswordBox x:Name="TxtSenha"
                                 Style="{StaticResource InputPasswordBoxStyle}"
                                 Margin="0,6,0,28"/>

                    <Button x:Name="BtnEntrar"
                            Content="Entrar"
                            Style="{StaticResource PrimaryButtonStyle}"
                            IsDefault="True"
                            Click="BtnEntrar_Click"/>

                    <Button Content="Criar conta"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,18,0,0"
                            Click="BtnCadastrar_Click"/>

                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>