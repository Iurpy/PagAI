<UserControl x:Class="PagAI.UI.Views.CadastroUsuarioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="480"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center">

            <TextBlock Text="PagAI"
                       FontSize="42"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Crie sua conta para começar"
                       FontSize="16"
                       Foreground="{StaticResource MutedBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,35"/>

            <Border Style="{StaticResource CardStyle}"
                    Padding="38">

                <StackPanel>

                    <TextBlock Text="Criar conta"
                               FontSize="28"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Preencha as informações abaixo"
                               FontSize="15"
                               Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,30"/>

                    <!-- Nome -->

                    <TextBlock Text="Nome"
                               Margin="0,0,0,6"/>

                    <TextBox x:Name="TxtNome"
                             Style="{StaticResource InputTextBoxStyle}"
                             Margin="0,0,0,18"/>

                    <!-- Login -->

                    <TextBlock Text="Login"
                               Margin="0,0,0,6"/>

                    <TextBox x:Name="TxtLogin"
                             Style="{StaticResource InputTextBoxStyle}"
                             Margin="0,0,0,18"/>

                    <!-- Senha -->

                    <TextBlock Text="Senha"
                               Margin="0,0,0,6"/>

                    <PasswordBox x:Name="TxtSenha"
                                 Style="{StaticResource InputPasswordBoxStyle}"
                                 Margin="0,0,0,18"/>

                    <!-- Confirmar -->

                    <TextBlock Text="Confirmar senha"
                               Margin="0,0,0,6"/>

                    <PasswordBox x:Name="TxtConfirmarSenha"
                                 Style="{StaticResource InputPasswordBoxStyle}"
                                 Margin="0,0,0,28"/>

                    <Button Content="Criar conta"
                            Style="{StaticResource PrimaryButtonStyle}"
                            IsDefault="True"
                            Click="BtnSalvar_Click"/>

                    <Button Content="Voltar para o login"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,14,0,0"
                            Click="BtnVoltar_Click"/>

                </StackPanel>

            </Border>

        </StackPanel>

    </Grid>

</UserControl>