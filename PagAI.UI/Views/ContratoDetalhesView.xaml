<UserControl x:Class="PagAI.UI.Views.ContratoDetalhesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#020617">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32">

            <DockPanel Margin="0,0,0,26">
                <Button Content="← Voltar"
                        DockPanel.Dock="Left"
                        Width="110"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="BtnVoltar_Click"/>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal">

                    <Button Content="Quitar Contrato"
                            Width="150"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="BtnQuitarContrato_Click"
                            Margin="0,0,12,0"/>

                    <Border Background="#1E293B"
                            CornerRadius="16"
                            Padding="18,10">

                        <TextBlock x:Name="TxtStatus"
                                   Text="Ativo"
                                   Foreground="#22C55E"
                                   FontSize="14"
                                   FontWeight="Bold"/>

                    </Border>
                </StackPanel>
            </DockPanel>

            <TextBlock x:Name="TxtTitulo"
                       Text="Detalhes do contrato"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="White"/>

            <TextBlock x:Name="TxtCliente"
                       Text="Cliente"
                       FontSize="15"
                       Foreground="#94A3B8"
                       Margin="0,6,0,28"/>

            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#0F172A"
                        CornerRadius="22"
                        Padding="24"
                        Margin="0,0,10,0">

                    <StackPanel>
                        <TextBlock Text="Valor emprestado"
                                   Foreground="#94A3B8"
                                   FontSize="13"/>

                        <TextBlock x:Name="TxtValorEmprestado"
                                   Text="R$ 0,00"
                                   Foreground="White"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                </Border>

                <Border Grid.Column="1"
                        Background="#0F172A"
                        CornerRadius="22"
                        Padding="24"
                        Margin="10,0">

                    <StackPanel>
                        <TextBlock Text="Total com juros"
                                   Foreground="#94A3B8"
                                   FontSize="13"/>

                        <TextBlock x:Name="TxtValorTotal"
                                   Text="R$ 0,00"
                                   Foreground="White"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                </Border>

                <Border Grid.Column="2"
                        Background="#0F172A"
                        CornerRadius="22"
                        Padding="24"
                        Margin="10,0,0,0">

                    <StackPanel>
                        <TextBlock Text="Parcelas"
                                   Foreground="#94A3B8"
                                   FontSize="13"/>

                        <TextBlock x:Name="TxtQuantidadeParcelas"
                                   Text="0"
                                   Foreground="White"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                </Border>
            </Grid>

            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#0F172A"
                        CornerRadius="22"
                        Padding="24"
                        Margin="0,0,10,0">

                    <StackPanel>
                        <TextBlock Text="Pagas"
                                   Foreground="#94A3B8"
                                   FontSize="13"/>

                        <TextBlock x:Name="TxtParcelasPagas"
                                   Text="0"
                                   Foreground="#22C55E"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                </Border>

                <Border Grid.Column="1"
                        Background="#0F172A"
                        CornerRadius="22"
                        Padding="24"
                        Margin="10,0">

                    <StackPanel>
                        <TextBlock Text="Pendentes"
                                   Foreground="#94A3B8"
                                   FontSize="13"/>

                        <TextBlock x:Name="TxtParcelasPendentes"
                                   Text="0"
                                   Foreground="#FACC15"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                </Border>

                <Border Grid.Column="2"
                        Background="#0F172A"
                        CornerRadius="22"
                        Padding="24"
                        Margin="10,0,0,0">

                    <StackPanel>
                        <TextBlock Text="Atrasadas"
                                   Foreground="#94A3B8"
                                   FontSize="13"/>

                        <TextBlock x:Name="TxtParcelasAtrasadas"
                                   Text="0"
                                   Foreground="#EF4444"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                </Border>
            </Grid>

            <Grid Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#0F172A"
                        CornerRadius="22"
                        Padding="24"
                        Margin="0,0,10,0">

                    <StackPanel>
                        <TextBlock Text="Total recebido"
                                   Foreground="#94A3B8"
                                   FontSize="13"/>

                        <TextBlock x:Name="TxtValorRecebido"
                                   Text="R$ 0,00"
                                   Foreground="#22C55E"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                </Border>

                <Border Grid.Column="1"
                        Background="#0F172A"
                        CornerRadius="22"
                        Padding="24"
                        Margin="10,0,0,0">

                    <StackPanel>
                        <TextBlock Text="Em aberto"
                                   Foreground="#94A3B8"
                                   FontSize="13"/>

                        <TextBlock x:Name="TxtValorEmAberto"
                                   Text="R$ 0,00"
                                   Foreground="#FACC15"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                </Border>
            </Grid>

            <Border Background="#0F172A"
                    CornerRadius="24"
                    Padding="28"
                    Margin="0,0,0,22">

                <StackPanel>
                    <TextBlock Text="Informações do contrato"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,22"/>

                    <TextBlock Text="Data do contrato"
                               Foreground="#94A3B8"
                               FontSize="13"/>

                    <TextBlock x:Name="TxtDataContrato"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,4,0,16"/>

                    <TextBlock Text="Primeiro vencimento"
                               Foreground="#94A3B8"
                               FontSize="13"/>

                    <TextBlock x:Name="TxtPrimeiroVencimento"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,4,0,16"/>

                    <TextBlock Text="Tipo de pagamento"
                               Foreground="#94A3B8"
                               FontSize="13"/>

                    <TextBlock x:Name="TxtTipoPagamento"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,4,0,16"/>

                    <TextBlock Text="Periodicidade"
                               Foreground="#94A3B8"
                               FontSize="13"/>

                    <TextBlock x:Name="TxtPeriodicidade"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                </StackPanel>

            </Border>

            <Border Background="#0F172A"
                    CornerRadius="24"
                    Padding="28">

                <StackPanel>
                    <TextBlock Text="Parcelas"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,22"/>

                    <ItemsControl x:Name="ListaParcelas">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E293B"
                                        CornerRadius="18"
                                        Padding="18"
                                        Margin="0,0,0,12">

                                    <StackPanel>

                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Left">
                                                <TextBlock Text="{Binding Numero}"
                                                           Foreground="White"
                                                           FontSize="17"
                                                           FontWeight="Bold"/>

                                                <TextBlock Text="{Binding Vencimento}"
                                                           Foreground="#94A3B8"
                                                           FontSize="13"
                                                           Margin="0,5,0,0"/>

                                                <TextBlock Text="{Binding Atraso}"
                                                           Foreground="#EF4444"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Margin="0,5,0,0"/>
                                            </StackPanel>

                                            <StackPanel DockPanel.Dock="Right"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">

                                                <StackPanel Margin="0,0,18,0">
                                                    <TextBlock Text="{Binding Valor}"
                                                               Foreground="White"
                                                               FontSize="17"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Right"/>

                                                    <TextBlock Text="{Binding ValorPago}"
                                                               Foreground="#22C55E"
                                                               FontSize="12"
                                                               HorizontalAlignment="Right"
                                                               Margin="0,5,0,0"/>

                                                    <TextBlock Text="{Binding ValorRestante}"
                                                               Foreground="#FACC15"
                                                               FontSize="12"
                                                               HorizontalAlignment="Right"
                                                               Margin="0,3,0,0"/>

                                                    <TextBlock Text="{Binding Multa}"
                                                               Foreground="#EF4444"
                                                               FontSize="12"
                                                               HorizontalAlignment="Right"
                                                               Margin="0,3,0,0"/>

                                                    <TextBlock Text="{Binding ValorComMulta}"
                                                               Foreground="#38BDF8"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Right"
                                                               Margin="0,3,0,0"/>

                                                    <TextBlock Text="{Binding Status}"
                                                               Foreground="#94A3B8"
                                                               FontSize="13"
                                                               HorizontalAlignment="Right"
                                                               Margin="0,5,0,0"/>
                                                </StackPanel>

                                                <Button Content="Receber"
                                                        Width="105"
                                                        Click="BtnReceberParcela_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button"
                                                               BasedOn="{StaticResource PrimaryButtonStyle}">
                                                            <Setter Property="Visibility"
                                                                    Value="Visible"/>

                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PodeReceber}"
                                                                             Value="False">
                                                                    <Setter Property="Visibility"
                                                                            Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </DockPanel>

                                        <ItemsControl ItemsSource="{Binding HistoricoPagamentos}"
              Margin="0,14,0,0">

    <ItemsControl.ItemTemplate>
        <DataTemplate>

            <Border Background="#0F172A"
                    CornerRadius="14"
                    Padding="12"
                    Margin="0,0,0,8">

                <DockPanel>

                    <StackPanel DockPanel.Dock="Left">

                        <TextBlock Text="{Binding Valor}"
                                   Foreground="#22C55E"
                                   FontWeight="Bold"
                                   FontSize="15"/>

                        <TextBlock Text="{Binding Data}"
                                   Foreground="#94A3B8"
                                   FontSize="12"
                                   Margin="0,4,0,0"/>

                        <TextBlock Text="{Binding Observacao}"
                                   Foreground="#CBD5E1"
                                   FontSize="12"
                                   Margin="0,2,0,0"/>

                    </StackPanel>

                </DockPanel>

            </Border>

        </DataTemplate>
    </ItemsControl.ItemTemplate>

</ItemsControl>

                                    </StackPanel>

                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>