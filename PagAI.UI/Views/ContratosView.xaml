<UserControl x:Class="PagAI.UI.Views.ContratosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#020617">

    <UserControl.Resources>

        <Style x:Key="BotaoPrimario" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Borda"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Borda" Property="Background" Value="#1D4ED8"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Borda" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BotaoSecundario" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Borda"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Borda" Property="Background" Value="#334155"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Margin="32">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   Margin="0,0,0,28">

            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Contratos"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock Text="Gerencie os empréstimos cadastrados"
                           FontSize="15"
                           Foreground="#94A3B8"
                           Margin="0,6,0,0"/>
            </StackPanel>

            <Button x:Name="BtnNovoContrato"
                    DockPanel.Dock="Right"
                    Content="+ Novo Contrato"
                    Width="180"
                    Style="{StaticResource BotaoPrimario}"
                    Click="BtnNovoContrato_Click"/>
        </DockPanel>

        <Border Grid.Row="1"
                Background="#0F172A"
                BorderBrush="#1E293B"
                BorderThickness="1"
                CornerRadius="16"
                Padding="18"
                Margin="0,0,0,22">

            <Grid>
                <TextBox x:Name="TxtPesquisar"
                         Height="46"
                         Background="#020617"
                         Foreground="White"
                         CaretBrush="White"
                         BorderBrush="#334155"
                         BorderThickness="1"
                         Padding="16,0"
                         FontSize="14"
                         VerticalContentAlignment="Center"
                         TextChanged="TxtPesquisar_TextChanged"/>

                <TextBlock Text="Pesquisar por título, cliente ou status..."
                           Foreground="#64748B"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=TxtPesquisar}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="#0F172A"
                BorderBrush="#1E293B"
                BorderThickness="1"
                CornerRadius="16"
                Padding="16">

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <ItemsControl x:Name="ListaContratos">

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Border Background="#020617"
                                    BorderBrush="#1E293B"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="18"
                                    Margin="0,0,0,12">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2.2*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="1.4*"/>
                                        <ColumnDefinition Width="1.4*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Titulo}"
                                                   Foreground="White"
                                                   FontSize="16"
                                                   FontWeight="Bold"/>

                                        <TextBlock Text="{Binding DataContrato, StringFormat=Criado em {0:dd/MM/yyyy}}"
                                                   Foreground="#64748B"
                                                   FontSize="12"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Cliente"
                                                   Foreground="#64748B"
                                                   FontSize="12"/>

                                        <TextBlock Text="{Binding Cliente.Nome}"
                                                   Foreground="#CBD5E1"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Emprestado"
                                                   Foreground="#64748B"
                                                   FontSize="12"/>

                                        <TextBlock Text="{Binding ValorEmprestado, StringFormat=R$ {0:N2}}"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="Total"
                                                   Foreground="#64748B"
                                                   FontSize="12"/>

                                        <TextBlock Text="{Binding ValorTotalComJuros, StringFormat=R$ {0:N2}}"
                                                   Foreground="#22C55E"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Parcelas"
                                                   Foreground="#64748B"
                                                   FontSize="12"/>

                                        <TextBlock Text="{Binding QuantidadeParcelas, StringFormat={}{0}x}"
                                                   Foreground="#CBD5E1"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="5">
                                        <TextBlock Text="Status"
                                                   Foreground="#64748B"
                                                   FontSize="12"/>

                                        <Border Background="#172554"
                                                CornerRadius="999"
                                                Padding="10,4"
                                                HorizontalAlignment="Left"
                                                Margin="0,5,0,0">
                                            <TextBlock Text="{Binding Status}"
                                                       Foreground="#60A5FA"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </StackPanel>

                                    <Button Grid.Column="6"
                                            Content="Detalhes"
                                            Click="BtnDetalhes_Click"
                                            Style="{StaticResource BotaoSecundario}"
                                            VerticalAlignment="Center"/>

                                </Grid>
                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </ScrollViewer>

        </Border>

    </Grid>
</UserControl>