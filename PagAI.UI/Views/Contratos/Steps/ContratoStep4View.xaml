<components:WizardStep x:Class="PagAI.UI.Views.Contratos.Steps.ContratoStep4View"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:components="clr-namespace:PagAI.UI.Components"
                       Background="Transparent">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">

            <TextBlock Text="Resumo do Contrato"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="White"/>

            <TextBlock Text="Confira os dados antes de salvar."
                       Margin="0,8,0,36"
                       FontSize="17"
                       Foreground="#CBD5E1"/>

        </StackPanel>

        <Grid Grid.Row="1"
              Margin="0,0,0,24">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#020617"
                    BorderBrush="#1E293B"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="18">

                <StackPanel>
                    <TextBlock Text="Valor emprestado"
                               Foreground="#94A3B8"
                               FontSize="13"/>

                    <TextBlock x:Name="TxtValorEmprestado"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="#020617"
                    BorderBrush="#1E293B"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="18">

                <StackPanel>
                    <TextBlock Text="Total com juros"
                               Foreground="#94A3B8"
                               FontSize="13"/>

                    <TextBlock x:Name="TxtValorTotal"
                               Foreground="#22C55E"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4"
                    Background="#020617"
                    BorderBrush="#1E293B"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="18">

                <StackPanel>
                    <TextBlock Text="Parcelas"
                               Foreground="#94A3B8"
                               FontSize="13"/>

                    <TextBlock x:Name="TxtParcelas"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

        </Grid>

        <Border Grid.Row="2"
                Background="#020617"
                BorderBrush="#1E293B"
                BorderThickness="1"
                CornerRadius="14"
                Padding="18">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0"
                           Margin="0,0,0,14">

                    <TextBlock Text="Parcelas geradas"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="TxtTotalParcelas"
                               DockPanel.Dock="Right"
                               Foreground="#94A3B8"
                               FontSize="14"
                               HorizontalAlignment="Right"/>
                </DockPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">

                    <ItemsControl x:Name="ListaParcelas">

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0F172A"
                                        BorderBrush="#1E293B"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="14"
                                        Margin="0,0,0,10">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="160"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Numero, StringFormat=Parcela {0}}"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"
                                                       FontSize="15"/>

                                            <TextBlock Text="Pendente"
                                                       Foreground="#60A5FA"
                                                       FontSize="12"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Vencimento"
                                                       Foreground="#64748B"
                                                       FontSize="12"/>

                                            <TextBlock Text="{Binding DataVencimento, StringFormat={}{0:dd/MM/yyyy}}"
                                                       Foreground="#CBD5E1"
                                                       FontSize="15"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2"
                                                    HorizontalAlignment="Right">
                                            <TextBlock Text="Valor"
                                                       Foreground="#64748B"
                                                       FontSize="12"
                                                       HorizontalAlignment="Right"/>

                                            <TextBlock Text="{Binding Valor, StringFormat=R$ {0:N2}}"
                                                       Foreground="#22C55E"
                                                       FontWeight="Bold"
                                                       FontSize="16"
                                                       Margin="0,4,0,0"
                                                       HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>

                </ScrollViewer>
            </Grid>
        </Border>

    </Grid>

</components:WizardStep>