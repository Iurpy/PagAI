<components:WizardStep x:Class="PagAI.UI.Views.Contratos.Steps.ContratoStep1View"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:components="clr-namespace:PagAI.UI.Components"
                       Background="Transparent">

    <components:WizardStep.Resources>

        <SolidColorBrush x:Key="BgCampo" Color="#020617"/>
        <SolidColorBrush x:Key="BgCampoHover" Color="#0F172A"/>
        <SolidColorBrush x:Key="BordaCampo" Color="#334155"/>
        <SolidColorBrush x:Key="BordaCampoAtivo" Color="#2563EB"/>
        <SolidColorBrush x:Key="TextoPrincipal" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextoSecundario" Color="#94A3B8"/>
        <SolidColorBrush x:Key="DropdownBg" Color="#020617"/>
        <SolidColorBrush x:Key="DropdownHover" Color="#1E293B"/>
        <SolidColorBrush x:Key="DropdownSelecionado" Color="#2563EB"/>

        <Style x:Key="LabelCampo" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="CampoTexto" TargetType="TextBox">
            <Setter Property="Height" Value="58"/>
            <Setter Property="Background" Value="{StaticResource BgCampo}"/>
            <Setter Property="Foreground" Value="{StaticResource TextoPrincipal}"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BordaCampo}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Borda"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Borda" Property="BorderBrush" Value="#475569"/>
                            </Trigger>

                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Borda" Property="BorderBrush" Value="{StaticResource BordaCampoAtivo}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ClienteSelecionadoTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="46"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="38"
                        Height="38"
                        CornerRadius="10"
                        Background="#1E3A8A"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding Nome[0]}"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0">
                    <TextBlock Text="{Binding Nome}"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="{Binding CPF, StringFormat=CPF: {0}}"
                               Foreground="#CBD5E1"
                               FontSize="13"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource DropdownBg}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource DropdownHover}"/>
                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource DropdownSelecionado}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboCliente" TargetType="ComboBox">
            <Setter Property="Height" Value="72"/>
            <Setter Property="Background" Value="{StaticResource BgCampo}"/>
            <Setter Property="Foreground" Value="{StaticResource TextoPrincipal}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BordaCampo}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,28"/>
            <Setter Property="ItemTemplate" Value="{StaticResource ClienteSelecionadoTemplate}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Borda"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="9"/>

                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{StaticResource ClienteSelecionadoTemplate}"
                                              Margin="18,0,52,0"
                                              VerticalAlignment="Center"/>

                            <ToggleButton Width="52"
                                          HorizontalAlignment="Right"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <Path Data="M 0 0 L 5 5 L 10 0 Z"
                                      Fill="#CBD5E1"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </ToggleButton>

                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="260"
                                        Margin="0,6,0,0"
                                        Background="#020617"
                                        BorderBrush="{StaticResource BordaCampoAtivo}"
                                        BorderThickness="1"
                                        CornerRadius="9">
                                    <ScrollViewer Margin="0,6">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Borda" Property="BorderBrush" Value="#475569"/>
                            </Trigger>

                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Borda" Property="BorderBrush" Value="{StaticResource BordaCampoAtivo}"/>
                            </Trigger>

                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Borda" Property="BorderBrush" Value="{StaticResource BordaCampoAtivo}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </components:WizardStep.Resources>

    <Grid>
        <StackPanel MaxWidth="1050"
                    HorizontalAlignment="Stretch">

            <TextBlock Text="Informações do Contrato"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="White"/>

            <TextBlock Text="Informe o cliente e os dados básicos do empréstimo."
                       Margin="0,8,0,36"
                       FontSize="17"
                       Foreground="#CBD5E1"/>

            <TextBlock Text="Cliente"
                       Style="{StaticResource LabelCampo}"/>

            <ComboBox x:Name="CmbClientes"
                      Style="{StaticResource ComboCliente}"/>

            <TextBlock Text="Título"
                       Style="{StaticResource LabelCampo}"/>

            <TextBox x:Name="TxtTitulo"
                     Style="{StaticResource CampoTexto}"/>

            <TextBlock Text="Valor emprestado"
                       Style="{StaticResource LabelCampo}"/>

            <Border Height="58"
                    Background="#020617"
                    BorderBrush="#334155"
                    BorderThickness="1"
                    CornerRadius="9"
                    Margin="0,0,0,28">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#111827"
                            CornerRadius="9,0,0,9"
                            BorderBrush="#334155"
                            BorderThickness="0,0,1,0">
                        <TextBlock Text="R$"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBox x:Name="TxtValor"
                             Grid.Column="1"
                             Background="Transparent"
                             Foreground="White"
                             CaretBrush="White"
                             BorderThickness="0"
                             Padding="18,0"
                             FontSize="16"
                             VerticalContentAlignment="Center"/>
                </Grid>
            </Border>

        </StackPanel>
    </Grid>

</components:WizardStep>