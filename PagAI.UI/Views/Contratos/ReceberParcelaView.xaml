<UserControl x:Class="PagAI.UI.Views.ReceberParcelaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#020617">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32"
                    MaxWidth="720">

            <Button Content="← Voltar"
                    Width="110"
                    HorizontalAlignment="Left"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="BtnVoltar_Click"
                    Margin="0,0,0,24"/>

            <TextBlock Text="Receber Parcela"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="White"/>

            <TextBlock x:Name="TxtDescricaoParcela"
                       Text="Parcela"
                       FontSize="15"
                       Foreground="#94A3B8"
                       Margin="0,6,0,28"/>

            <Border Background="#0F172A"
                    CornerRadius="24"
                    Padding="28">

                <StackPanel>

                    <TextBlock Text="Valor da parcela"
                               Foreground="#94A3B8"
                               FontSize="13"/>

                    <TextBlock x:Name="TxtValorParcela"
                               Text="R$ 0,00"
                               Foreground="White"
                               FontSize="28"
                               FontWeight="Bold"
                               Margin="0,6,0,16"/>

                    <TextBlock Text="Já pago"
                               Foreground="#94A3B8"
                               FontSize="13"/>

                    <TextBlock x:Name="TxtValorJaPago"
                               Text="R$ 0,00"
                               Foreground="#22C55E"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,6,0,16"/>

                    <TextBlock Text="Restante"
                               Foreground="#94A3B8"
                               FontSize="13"/>

                    <TextBlock x:Name="TxtValorRestante"
                               Text="R$ 0,00"
                               Foreground="#FACC15"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,6,0,24"/>

                    <TextBlock Text="Valor recebido agora"
                               Foreground="#CBD5E1"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <TextBox x:Name="TxtValorRecebido"
                             Height="44"
                             Background="#1E293B"
                             Foreground="White"
                             BorderBrush="#334155"
                             BorderThickness="1"
                             FontSize="15"
                             Padding="12,0"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,18"/>

                    <TextBlock Text="Data do pagamento"
                               Foreground="#CBD5E1"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <TextBox x:Name="TxtDataPagamento"
                             Height="44"
                             Background="#1E293B"
                             Foreground="White"
                             BorderBrush="#334155"
                             BorderThickness="1"
                             FontSize="15"
                             Padding="12,0"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,18"/>

                    <TextBlock Text="Observação"
                               Foreground="#CBD5E1"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <TextBox x:Name="TxtObservacao"
                             Height="90"
                             Background="#1E293B"
                             Foreground="White"
                             BorderBrush="#334155"
                             BorderThickness="1"
                             FontSize="15"
                             Padding="12"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,26"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">

                        <Button Content="Cancelar"
                                Width="120"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="BtnVoltar_Click"
                                Margin="0,0,12,0"/>

                        <Button Content="Confirmar Recebimento"
                                Width="210"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="BtnConfirmarRecebimento_Click"/>

                    </StackPanel>

                </StackPanel>

            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>