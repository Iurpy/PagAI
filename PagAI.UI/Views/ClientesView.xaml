<UserControl x:Class="PagAI.UI.Views.ClientesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- CABEÇALHO -->
        <DockPanel Margin="0,0,0,24">

            <StackPanel>
                <TextBlock Text="Clientes"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock Text="Gerencie seus clientes cadastrados"
                           FontSize="14"
                           Foreground="{StaticResource MutedBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <Button Content="+ Novo Cliente"
                    Width="165"
                    Height="44"
                    DockPanel.Dock="Right"
                    HorizontalAlignment="Right"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="BtnNovoCliente_Click"/>
        </DockPanel>

        <!-- FILTROS -->
        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}"
                Margin="0,0,0,18"
                Padding="18">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TxtPesquisar"
                         Style="{StaticResource InputTextBoxStyle}"
                         FontSize="14"
                         TextChanged="TxtPesquisar_TextChanged"/>

                <Border Grid.Column="1"
                        Background="#0B1220"
                        CornerRadius="10"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        Padding="14,0"
                        Height="42"
                        Margin="14,0,0,0">

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <TextBlock Text="Clientes"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>

                        <TextBlock Text=" ativos"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- LISTA -->
        <Border Grid.Row="2"
                Style="{StaticResource CardStyle}"
                Margin="0"
                Padding="0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER DA LISTA -->
                <Border Grid.Row="0"
                        Background="#0B1220"
                        CornerRadius="16,16,0,0"
                        BorderBrush="#1E293B"
                        BorderThickness="0,0,0,1"
                        Padding="18,0">

                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*"/>
                            <ColumnDefinition Width="1.4*"/>
                            <ColumnDefinition Width="1.4*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Cliente"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="Telefone"
                                   Grid.Column="1"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="CPF"
                                   Grid.Column="2"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="Ações"
                                   Grid.Column="3"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"
                                   Margin="0,0,30,0"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="14">

                    <ItemsControl x:Name="ListaClientes">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>

                                <Border Background="#0B1220"
                                        CornerRadius="14"
                                        Padding="14"
                                        Margin="0,0,0,10"
                                        BorderBrush="#1E293B"
                                        BorderThickness="1">

                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#0B1220"/>
                                            <Setter Property="BorderBrush" Value="#1E293B"/>

                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#111827"/>
                                                    <Setter Property="BorderBrush" Value="#334155"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.2*"/>
                                            <ColumnDefinition Width="1.4*"/>
                                            <ColumnDefinition Width="1.4*"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- CLIENTE -->
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">

                                            <Border Width="38"
                                                    Height="38"
                                                    CornerRadius="12"
                                                    Background="#172554"
                                                    Margin="0,0,12,0">

                                                <TextBlock Text="{Binding Nome[0]}"
                                                           Foreground="White"
                                                           FontSize="16"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Nome}"
                                                           Foreground="White"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"/>

                                                <TextBlock Text="{Binding Apelido}"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           FontSize="12"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- TELEFONE -->
                                        <TextBlock Text="{Binding Telefone}"
                                                   Grid.Column="1"
                                                   Foreground="#CBD5E1"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"/>

                                        <!-- CPF -->
                                        <TextBlock Text="{Binding CPF}"
                                                   Grid.Column="2"
                                                   Foreground="#CBD5E1"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"/>

                                        <!-- AÇÕES -->
                                        <StackPanel Grid.Column="3"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center">

                                            <Button Content="Editar"
                                                    Width="68"
                                                    Height="32"
                                                    Margin="0,0,8,0"
                                                    Style="{StaticResource SecondaryButtonStyle}"/>

                                            <Button Content="Excluir"
                                                    Width="72"
                                                    Height="32"
                                                    Background="#450A0A"
                                                    Foreground="#FCA5A5"
                                                    Style="{StaticResource PrimaryButtonStyle}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>